{
  "name": "fscss",
  "displayName": "FSCSS Support",
  "publisher": "figsh",
  "description": "Syntax highlighting and tools for FSCSS",
  "version": "1.0.6",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icons/fscss-logo.png", 
  "categories": ["Programming Languages", "Snippets"],
  "repository": {
  "type": "git",
  "url": "https://github.com/Figsh/fscss-vscode-extension"
},
  "homepage": "https://fscss.devtem.org", 
  "keywords": ["fscss", "css", "preprocessor", "syntax", "xfscss", "figsh"],
  "license": "MIT", 
  "bugs": {
     "url": "https://github.com/Figsh/fscss-vscode-extension/issues"
  }, 
   "contributes": {
    "languages": [
      {
        "id": "fscss",
        "aliases": ["FSCSS", "fscss"],
        "extensions": [".fscss", ".xfscss"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "icons/fscss-icon.png",
          "dark": "icons/fscss-icon.png"
        }
      }
    ],
    "snippets": [
      {
        "language": "fscss",
        "path": "./snippets/fscss.json"
      }
    ], 
    "grammars": [
      {
        "language": "fscss",
        "scopeName": "source.fscss",
        "path": "./syntaxes/fscss.tmLanguage.json"
      }
    ]
  },
  "main": "./extension.js"
}
