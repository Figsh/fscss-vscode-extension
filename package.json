{
  "name": "fscss",
  "displayName": "FSCSS Support",
  "description": "Syntax highlighting and tools for FSCSS",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icons/fscss-logo.png", 
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "fscss",
        "aliases": ["FSCSS", "fscss"],
        "extensions": [".fscss", ".xfscss"],
        "configuration": "./language-configuration.json", 
        "icon": {
          "light": "./icons/fscss-light.svg",
          "dark": "./icons/fscss-dark.svg"
        }
      }
    ],
    "snippets": [
  {
    "language": "fscss",
    "path": "./snippets/fscss.json"
  }
], 
    "grammars": [
      {
        "language": "fscss",
        "scopeName": "source.fscss",
        "path": "./syntaxes/fscss.tmLanguage.json"
      }
    ]
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:fscss"
  ]
}
