{
  "FSCSS Define Function": {
    "prefix": "def",
    "body": [
      "@define ${1:name}(${2:args}){",
      "  ${3}",
      "}"
    ],
    "description": "Create an FSCSS function"
  },
  
  "FSCSS Import": {
    "prefix": "imp",
    "body": [
      "@import((${1:module}) from \"${2:path}\")"
    ],
    "description": "Import FSCSS module"
  },
  
  "FSCSS Array": {
    "prefix": "arr",
    "body": [
      "@arr ${1:name}[${2:values}]"
    ],
    "description": "Create FSCSS array"
  },
  
  "FSCSS Use": {
    "prefix": "key",
    "body": [
      "$(@keyframes ${1:name}, ${2:selector} &[3s linear infinite alternate]){",
      "  ${3}",
      "}"
    ],
    "description": "Keyframes shorthand"
  },
  
  "FSCSS Shorthand %": {
    "prefix": "pct",
    "body": [
      "%${1:number}(${2:properties}[:${3:value};])"
    ],
    "description": "FSCSS shorthand function"
  }
}

