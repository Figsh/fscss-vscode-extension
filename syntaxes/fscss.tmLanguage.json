{
  "name": "FSCSS",
  "scopeName": "source.fscss",
  "patterns": [
    { "include": "#comments" },
    { "include": "#fscss-expressions" },
    { "include": "#block" },
    { "include": "#paren" },
    { "include": "source.css" }
  ],
  "repository": {
    "comments": {
      "comment": "Double slash comments",
      "match": "//.*$",
      "name": "comment.line.double-slash.fscss"
    },
    "fscss-expressions": {
      "patterns": [
        {
          "comment": "Property names — Improved to catch prefixes and maintain priority",
          "match": "(?<![-])\\b([-a-zA-Z_][-a-zA-Z0-9_]*)(?=\\s*:)",
          "name": "support.type.property-name.css"
        },
        {
          "comment": "FSCSS variables with optional force operator",
          "match": "\\$\\/?[a-zA-Z_][a-zA-Z0-9_-]*\\s*(!)?",
          "captures": {
            "0": { "name": "variable.other.fscss" },
            "1": { "name": "keyword.operator.force.fscss" }
          }
        },
        {
          "comment": "Special keywords",
          "match": "\\b(_init|if|el-if|el|return|_log|from|as|to)\\b",
          "name": "keyword.other.special.fscss"
        },
        {
          "comment": "FSCSS define + name (two-tone)",
          "match": "@(define|arr|obj|event)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "keyword.control.fscss" },
            "2": { "name": "entity.name.function.fscss" }
          }
        },
        {
          "comment": "FSCSS dot-access e.g. @arr.colors @obj.theme",
          "match": "@(arr|event|obj)\\.([a-zA-Z_][a-zA-Z0-9_-]+)\\b",
          "captures": {
            "1": { "name": "keyword.control.fscss" },
            "2": { "name": "entity.name.function.fscss" }
          }
        },
        {
          "comment": "FSCSS control directives",
          "match": "@(import|use|random|ext|fun)\\b",
          "name": "keyword.control.fscss"
        },
        {
          "comment": "FSCSS custom/generic function calls e.g. @button()",
          "match": "@[a-zA-Z_][a-zA-Z0-9_-]+(?=\\()",
          "name": "entity.name.function.fscss"
        },
        {
          "comment": "FSCSS built-in functions",
          "match": "\\b(exec|find|pick|length|count|copy|str|re|store|join|prefix|surround|unit|block|num|rpt|mx|mxs)(?=\\s*\\()",
          "name": "support.function.fscss"
        },
        {
          "comment": "FSCSS method helpers e.g. .randint .list",
          "match": "\\.(length|last|reverse|first|list|indices|randint|segment|map|sum|unique|sort|shuffle|min|max|obj|xfscss)\\b",
          "name": "entity.name.function.method.fscss"
        },
        {
          "match": "\\|\\|",
          "name": "keyword.variable.fallback.fscss"
        },
        {
          "match": "%[0-9]+(?=\\()",
          "name": "constant.numeric.fscss"
        },
        {
          "name": "string.quoted.double.fscss",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.fscss", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.fscss",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.fscss", "match": "\\\\." }
          ]
        },
        {
          "name": "string.template.fscss",
          "begin": "`",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.fscss" }
          },
          "end": "`",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.fscss" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#fscss-expressions" },
            { "include": "#paren" },
            { "include": "#block" },
            { "include": "source.css" }
          ]
        }
      ]
    },
    "paren": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.section.parens.begin.fscss" } },
      "endCaptures": { "0": { "name": "punctuation.section.parens.end.fscss" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#fscss-expressions" },
        { "include": "#paren" },
        { "include": "source.css" }
      ]
    },
    "block": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.block.begin.fscss" } },
      "endCaptures": { "0": { "name": "punctuation.section.block.end.fscss" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#fscss-expressions" },
        { "include": "#block" },
        { "include": "source.css" }
      ]
    }
  }
}

